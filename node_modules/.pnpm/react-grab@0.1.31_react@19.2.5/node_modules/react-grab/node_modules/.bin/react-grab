#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules/@react-grab/cli/dist/node_modules:/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules/@react-grab/cli/node_modules:/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules/@react-grab/node_modules:/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules:/home/project/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules/@react-grab/cli/dist/node_modules:/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules/@react-grab/cli/node_modules:/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules/@react-grab/node_modules:/home/project/node_modules/.pnpm/@react-grab+cli@0.1.31/node_modules:/home/project/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@react-grab+cli@0.1.31/node_modules/@react-grab/cli/dist/cli.js" "$@"
else
  exec node  "$basedir/../../../../../@react-grab+cli@0.1.31/node_modules/@react-grab/cli/dist/cli.js" "$@"
fi
